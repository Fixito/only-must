{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/*.gen.ts", "**/drizzle/**"],
  "arrowParens": "always",
  "endOfLine": "lf",
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "sortImports": true,
  "overrides": [
    {
      "files": ["apps/web/**/*.{ts,tsx}"],
      "options": {
        "jsxSingleQuote": false
      }
    }
  ]
}
